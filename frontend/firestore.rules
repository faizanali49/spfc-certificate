// firestore.rules
// Deploy with: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Certificates ──────────────────────────────────────────
    // Document ID = the applicant's CNIC (digits only, dashes stripped).
    // This makes public verification a direct getDoc() lookup — fast,
    // cheap, and scales independently of total record count.
    match /certificates/{docId} {

      // Public: read only — used by the CNIC + captcha verification page.
      // CNIC is stored and displayed in plain text per project requirements.
      allow read: if true;

      // Write: only authenticated admin (any logged-in Firebase user).
      // Covers both setDoc (used for new certificates, since the doc ID
      // is the CNIC) and updateDoc (used for edits).
      allow create, update: if request.auth != null;

      // Delete: only authenticated admin
      allow delete: if request.auth != null;
    }

    // ── Dropdown Lists (Purpose, Purpose of Obtaining, Cities) ──
    match /dropdown_lists/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Legacy purposes collection (if still in use) ──────────
    match /purposes/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Deny all other collections ────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
